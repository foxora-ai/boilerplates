{
  "name": "qwik-boilerplate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --outDir server/preview --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/express/vite.config.ts",
    "deploy": "node server/server.js",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "lint": "eslint --ext .ts,.tsx .",
    "preview": "qwik build preview && node server/preview/server.mjs",
    "start": "vite --open --mode ssr",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.9.0",
    "@builder.io/qwik-city": "^1.9.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0"
  }
}
