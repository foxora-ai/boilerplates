---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Astro Boilerplate">
  <main class="flex min-h-screen flex-col items-center justify-center">
    <h1 class="text-4xl font-bold">Astro Boilerplate</h1>
    <p class="mt-4 text-gray-500 dark:text-gray-400">
      Edit <code class="font-mono bg-gray-100 dark:bg-gray-800 px-1 rounded">src/pages/index.astro</code> to get started.
    </p>
    <p class="mt-2 text-sm text-gray-400">Zero JS by default · Islands architecture</p>
  </main>
</BaseLayout>
